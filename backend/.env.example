#
# Backend env example (NearStep)
#
# Copy to .env and fill your own values:
#   cd backend
#   cp .env.example .env
#

# Server
PORT=4000
CORS_ORIGIN=http://127.0.0.1:3000

# Supabase (required for favorites and JWT verification)
# SUPABASE_URL should look like:
#   https://<project-ref>.supabase.co
SUPABASE_URL=

# Service role key (server-side only, NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# JWKS URL for JWT verification:
#   https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=

# Cache
CACHE_TTL_SECONDS=86400

# OSM providers
# OSM_USER_AGENT is required for real OSM mode (public instances).
# It should include a contact (email or link) and be at least 3 chars.
OSM_USER_AGENT=nearstep (contact: you@example.com)
OSM_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OSM_OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter

# Optional: enable mock OSM provider (used by e2e/CI)
# OSM_MOCK=1

# Optional: credentials for auth-related e2e test
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=your-password

# Logging (structured JSON to stdout; captured by Vercel Runtime Logs)
# LOG_LEVEL=info
