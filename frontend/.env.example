#
# Frontend env example (NearStep)
#
# Copy to .env.local and fill your own values:
#   cd frontend
#   cp .env.example .env.local
#

# Backend base URL (Fastify)
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:4000

# Supabase (public client config)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Яндекс.Метрика — номер счётчика (https://metrika.yandex.ru/)
# NEXT_PUBLIC_YM_COUNTER_ID=

# опционально:
# NEXT_PUBLIC_BASE_PATH=
# NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
